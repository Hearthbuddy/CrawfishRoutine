<UserControl x:Class="CrawfishRoutine.SettingsGui"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <TextBlock Text="龙虾版天梯策略设置" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
        <CheckBox Content="启用回放录制" IsChecked="{Binding EnableReplayRecording, Mode=TwoWay}" Margin="0,5,0,5"/>
        <CheckBox Content="启用策略AI" IsChecked="{Binding EnableStrategy, Mode=TwoWay}" Margin="0,5,0,5"/>
        <Grid Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="回放目录：" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="1" Text="{Binding ReplayDirectory, Mode=TwoWay}" VerticalAlignment="Center"/>
        </Grid>
    </StackPanel>
</UserControl>
